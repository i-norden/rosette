# ============================================================
# Rosette - Environment Variables
# ============================================================
# Copy this file to .env and fill in the values.
#   cp .env.example .env
# ============================================================

# --- API Keys ---

# Required: Anthropic API key for Claude LLM access
ANTHROPIC_API_KEY=sk-ant-...

# Optional: Discovery service API keys (improves paper discovery)
ROSETTE__DISCOVERY__OPENALEX_API_KEY=
ROSETTE__DISCOVERY__SEMANTIC_SCHOLAR_API_KEY=
ROSETTE__DISCOVERY__NCBI_API_KEY=

# Required for PDF download via Unpaywall API
UNPAYWALL_EMAIL=your-email@example.com

# --- LLM Configuration ---

# LLM provider (default: claude)
ROSETTE__LLM__PROVIDER=claude

# Model overrides (defaults shown)
ROSETTE__LLM__MODEL_SCREEN=claude-haiku-4-5-20251001
ROSETTE__LLM__MODEL_ANALYZE=claude-sonnet-4-5-20250929
ROSETTE__LLM__MODEL_PROOF=claude-opus-4-6

# Use batch API for bulk processing (default: true)
ROSETTE__LLM__USE_BATCH_API=true

# Max concurrent LLM requests (default: 5)
ROSETTE__LLM__MAX_CONCURRENT_REQUESTS=5

# --- Storage ---

# Database URL (SQLite for local dev, PostgreSQL for production)
# Local:      sqlite:///rosette.db
# Docker:     postgresql+asyncpg://rosette:rosette@postgres:5432/rosette
ROSETTE__STORAGE__DATABASE_URL=sqlite:///rosette.db

# Data directories
ROSETTE__STORAGE__PDF_DIR=data/pdfs
ROSETTE__STORAGE__FIGURES_DIR=data/figures
ROSETTE__STORAGE__REPORTS_DIR=data/reports

# --- Priority / Filtering ---

# Minimum citation count for paper prioritization (default: 50)
ROSETTE__PRIORITY__MIN_CITATIONS=50

# Journal quartile filter (default: Q1)
ROSETTE__PRIORITY__JOURNAL_QUARTILE_FILTER=Q1

# Minimum priority score to process a paper (default: 40)
ROSETTE__PRIORITY__MIN_PRIORITY_SCORE=40

# --- Analysis ---

# ELA (Error Level Analysis) quality setting (default: 95)
ROSETTE__ANALYSIS__ELA_QUALITY=80

# Minimum clone detection matches (default: 10)
ROSETTE__ANALYSIS__CLONE_MIN_MATCHES=10

# --- Docker / PostgreSQL ---

# Password for the Postgres container (docker-compose)
POSTGRES_PASSWORD=CHANGE_ME_USE_STRONG_PASSWORD

# Noise analysis block size (default: 64)
ROSETTE__ANALYSIS__NOISE_BLOCK_SIZE=64

# LLM screening confidence threshold (default: 0.5)
ROSETTE__ANALYSIS__LLM_SCREENING_CONFIDENCE_THRESHOLD=0.5

# Require convergence across methods (default: true)
ROSETTE__ANALYSIS__CONVERGENCE_REQUIRED=true
