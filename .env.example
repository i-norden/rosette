# ============================================================
# Snoopy - Environment Variables
# ============================================================
# Copy this file to .env and fill in the values.
#   cp .env.example .env
# ============================================================

# --- API Keys ---

# Required: Anthropic API key for Claude LLM access
ANTHROPIC_API_KEY=sk-ant-...

# Optional: Discovery service API keys (improves paper discovery)
SNOOPY__DISCOVERY__OPENALEX_API_KEY=
SNOOPY__DISCOVERY__SEMANTIC_SCHOLAR_API_KEY=
SNOOPY__DISCOVERY__NCBI_API_KEY=

# Required for PDF download via Unpaywall API
UNPAYWALL_EMAIL=your-email@example.com

# --- LLM Configuration ---

# LLM provider (default: claude)
SNOOPY__LLM__PROVIDER=claude

# Model overrides (defaults shown)
SNOOPY__LLM__MODEL_SCREEN=claude-haiku-4-5-20251001
SNOOPY__LLM__MODEL_ANALYZE=claude-sonnet-4-5-20250929
SNOOPY__LLM__MODEL_PROOF=claude-opus-4-6

# Use batch API for bulk processing (default: true)
SNOOPY__LLM__USE_BATCH_API=true

# Max concurrent LLM requests (default: 5)
SNOOPY__LLM__MAX_CONCURRENT_REQUESTS=5

# --- Storage ---

# Database URL (SQLite for local dev, PostgreSQL for production)
# Local:      sqlite:///snoopy.db
# Docker:     postgresql+asyncpg://snoopy:snoopy@postgres:5432/snoopy
SNOOPY__STORAGE__DATABASE_URL=sqlite:///snoopy.db

# Data directories
SNOOPY__STORAGE__PDF_DIR=data/pdfs
SNOOPY__STORAGE__FIGURES_DIR=data/figures
SNOOPY__STORAGE__REPORTS_DIR=data/reports

# --- Priority / Filtering ---

# Minimum citation count for paper prioritization (default: 50)
SNOOPY__PRIORITY__MIN_CITATIONS=50

# Journal quartile filter (default: Q1)
SNOOPY__PRIORITY__JOURNAL_QUARTILE_FILTER=Q1

# Minimum priority score to process a paper (default: 40)
SNOOPY__PRIORITY__MIN_PRIORITY_SCORE=40

# --- Analysis ---

# ELA (Error Level Analysis) quality setting (default: 95)
SNOOPY__ANALYSIS__ELA_QUALITY=95

# Minimum clone detection matches (default: 10)
SNOOPY__ANALYSIS__CLONE_MIN_MATCHES=10

# --- Docker / PostgreSQL ---

# Password for the Postgres container (docker-compose)
POSTGRES_PASSWORD=snoopy

# Noise analysis block size (default: 64)
SNOOPY__ANALYSIS__NOISE_BLOCK_SIZE=64

# LLM screening confidence threshold (default: 0.5)
SNOOPY__ANALYSIS__LLM_SCREENING_CONFIDENCE_THRESHOLD=0.5

# Require convergence across methods (default: true)
SNOOPY__ANALYSIS__CONVERGENCE_REQUIRED=true
